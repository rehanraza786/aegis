  },
  "homepage": "https://github.com/rehanraza786/aegis#readme",
  "keywords": ["mcp", "code-graph", "copilot", "claude", "kafka", "liquibase", "static-analysis"],
  "bin": {
    "aegis-ariadne": "./server.mjs",
    "aegis-ariadne-index": "./indexer.mjs",
